<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Donation Receipt</title>
 <style>
  /* =============================================
   Being Sevak Receipt - Exact Design Match
   ============================================= */

@import url('https://fonts.googleapis.com/css2?family=Times+New+Roman&family=Arial&display=swap');

 /* =========================
   GLOBAL RESET
========================= */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Segoe UI", Arial, sans-serif;
}

body {
  background: #f2f6fa;
  padding: 20px;
}

/* =========================
   PAGE WRAPPER
========================= */
.page {
  max-width: 900px;
  margin: auto;
}

/* =========================
   MAIN RECEIPT BOX
========================= */
.receipt-box {
  background: #fff;
  border: 2px solid #00a3da;
  border-radius: 10px;
  padding: 22px;
  margin-bottom: 20px;
}

/* =========================
   HEADER SECTION
========================= */

.header{
    width:100%;
    display:table;
    border-bottom:2px solid #00a3da;
    padding-bottom:12px;
    margin-bottom:10px;
}

.logo-area{
    display:table-cell;
    width:90px;
    vertical-align:top;
}

.logo-img{
    width:70px;
    height:auto;
    display:block;
}

.org-name-area{
    display:table-cell;
    text-align:center;
    vertical-align:middle;
    padding:0 10px;
}

.tagline{
    font-size:13px;
    font-weight:600;
    color:#00a3da;
    margin-bottom:5px;
    line-height:1.2;
}

.logo-box{
    width:100%;
    text-align:center;
    margin-bottom:4px;
}

.logo-box img{
    max-width:280px;
    height:32px;
    display:inline-block;
}

.reg-line{
    font-size:11px;
    color:#000;
    line-height:1.3;
    text-align:center;
}

/* PRINT FIX */
@media print{

    .header{
        display:table !important;
        width:100% !important;
        page-break-inside:avoid;
    }

    .logo-area{
        display:table-cell !important;
        width:90px !important;
        vertical-align:top !important;
    }

    .org-name-area{
        display:table-cell !important;
        text-align:center !important;
        vertical-align:middle !important;
    }

    .logo-img{
        width:70px !important;
        height:auto !important;
    }

    .logo-box img{
        max-width:280px !important;
        height:32px !important;
    }
}
/* =========================
   TITLE BAR (CLEAN GOV STYLE)
========================= */
/* =========================
   TITLE BAR (PRINT SAFE)
========================= */

.title-bar{
    width:100%;
    display:table;
    table-layout:fixed;

    margin-top:12px;
    border:2px solid #00a3da;
    border-radius:6px;
    background:#eaf8ff;
    padding:10px 0;
    box-sizing:border-box;
}

.receipt-meta,
.cert-title{
    display:table-cell;
    vertical-align:middle;
}

.receipt-meta{
    width:25%;
    font-size:13px;
    color:#333;
    font-weight:500;
}

.receipt-meta.left{
    text-align:left;
    padding-left:12px;
}

.receipt-meta.right{
    text-align:right;
    padding-right:12px;
}

.cert-title{
    width:50%;
    text-align:center;
    font-weight:700;
    color:#00a3da;
    letter-spacing:1px;
    font-size:16px;
}

/* PRINT FIX */
@media print{

    .title-bar{
        display:table !important;
        width:100% !important;
        page-break-inside:avoid;
    }

    .receipt-meta,
    .cert-title{
        display:table-cell !important;
        vertical-align:middle !important;
    }
}
/* =========================
   BODY TEXT
========================= */
.letter-body {
  margin-top: 18px;
  font-size: 14px;
  line-height: 1.7;
  color: #222;
}

.letter-body strong {
  color: #00a3da;
}

.amount-inline {
  font-weight: 700;
  border-bottom: 2px solid #00a3da;
  padding-bottom: 2px;
}

.amount-figure {
  font-weight: 700;
  margin-left: 8px;
  color: #0a3d62;
}

/* =========================
   TABLE (PROPER BOX GRID)
========================= */
.fields-table {
  width: 100%;
  margin-top: 18px;
  border-collapse: collapse;
  border: 2px solid #00a3da;
}

.fields-table td {
  border: 1px solid #00a3da;
  padding: 10px;
  font-size: 13px;
}

.label {
  font-weight: 700;
  color: #00a3da;
  background: #f3fbff;
  width: 25%;
}

.value {
  font-weight: 600;
  color: #222;
  background: #fff;
}

.text-right {
  text-align: right;
}

/* =========================
   AMOUNT + PAN BOX (IMPORTANT FIX)
========================= */
.amount-row {
  display: flex;
  gap: 20px;
  margin-top: 18px;
}

/* MAIN BOX WITH BORDER */
.amount-box {
  flex: 1;
  border: 2px solid #00a3da;
  border-radius: 8px;
  padding: 14px;
  background: #ffffff;
}

/* AMOUNT LINE */
.amount-value-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 700;
  border-bottom: 1px solid #00a3da;
  padding-bottom: 8px;
  margin-bottom: 8px;
}

.amount-header {
  color: #00a3da;
  font-weight: 800;
}

.rs {
  background: #00a3da;
  color: #fff;
  padding: 3px 8px;
  font-size: 12px;
}

.amount-value {
  font-size: 18px;
  color: #0a3d62;
}

.pan-label {
  margin-left: auto;
  font-weight: 700;
  color: #00a3da;
}

.pan-value {
  font-weight: 700;
  color: #222;
}

/* NOTES */
.realisation-note,
.email-row,
.system-note {
  font-size: 11px;
  color: #555;
  margin-top: 5px;
}

/* =========================
   SEAL BOX (WITH BORDER)
========================= */
.seal-area {
  width: 180px;
  border: 2px solid #00a3da;
  border-radius: 8px;
  text-align: center;
  padding: 10px;
  background: #f9fdff;
}

.seal-img {
  width: 85px;
}

.auth-sign {
  margin-top: 8px;
  font-size: 12px;
  font-weight: 700;
  color: #00a3da;
}

/* =========================
   SEPARATOR LINE
========================= */
.dashed-sep {
  margin: 20px 0;
  border-top: 2px dashed #00a3da;
}

/* =========================
   RESPONSIVE
========================= */
@media (max-width: 768px) {
  .header {
    flex-direction: column;
    text-align: center;
  }

  .amount-row {
    flex-direction: column;
  }

  .title-bar {
    flex-direction: column;
    gap: 6px;
    text-align: center;
  }
}
/* print */

</style>
</head>
<body>
  <div class="page">

    <!-- ===== TOP SECTION: Thank You Letter ===== -->
    <div class="receipt-box top-box">

      <!-- Header -->
     <div class="header">

    <div class="logo-area">
        <img src="logo.jpg" alt="Logo" class="logo-img">
    </div>

    <div class="org-name-area">

        <div class="tagline">
            We Rise By Lifting Others
        </div>

        <div class="logo-box">
            <img src="logo2.jpeg" alt="Being Sevak Logo">
        </div>

        <div class="reg-line">
            Charity Commissioner (Reg.) No: E-31948 &nbsp;|&nbsp;
            Income Tax Exempted Under 80G No: AACTB6422FF20214
        </div>

    </div>

</div>

      <!-- Title Bar -->
    <div class="title-bar">

    <div class="receipt-meta left">
        Receipt No:<strong id="receipt-no-top">79298</strong>
    </div>

    <div class="cert-title">
        80G CERTIFICATE OF DONATION
    </div>

    <div class="receipt-meta right">
        Date: <strong id="receipt-date-top">1-Jun-26</strong>
    </div>

</div>

      <!-- Body -->
      <div class="letter-body">
        <p><strong>NAME: &nbsp;&nbsp;<span id="donor-name-top">Subramanyam Sridhar</span></strong></p>
        <p>Dear Sir/Madam,</p>
        <p>
          <strong>Being Sevak Charitable Trust</strong>, would like to thanks you for your generous donation of
          <strong class="amount-inline" id="amount-words-top">One Thousand Five Hundred Rupees and No: Paise Only</strong>
          <span class="amount-figure" id="amount-fig-top">Rs. 1,500.00</span>
          for noble cause &amp; Make a Difference.
        </p>
        <p>
          Your financial support helps us to continue in our mission. With the valuable support of donor <strong>LIKE YOU</strong>,
          We are be able to help many of needy families and individuals for not only to meet essential daily needs, but to
          manage their live-hood through our different activities like Food-grain Kit Distribution, Medical Kit Distribution,
          Education Facilities &amp; many other activities.
        </p>
        <p>Please keep this written acknowledgement of your donation for your tax records.</p>
        <p>
          We thank you once again for your support and love we have received from you, We also hope forward to
          your continued support.
        </p>
        <p>Thanking you,<br/>Yours truly,<br/><strong>Being Sevak Charitable Trust</strong></p>
        <p class="note-line">
          Note: Your Donation to Being Sevak Charitable Trust Is Eligible For 50% Tax Rebate [U/S 80G of Income Tax Act 1961]
        </p>
      </div>
    </div>

    <!-- Dashed separator -->
    <div class="dashed-sep"></div>


    

    <!-- ===== BOTTOM SECTION: Formal Receipt ===== -->
    <div class="receipt-box bottom-box">

      <!-- Header -->
      <div class="header">
        <div class="logo-area">
          <img src="logo.jpg" alt="Trust Logo" class="logo-img"  />
        </div>
        <div class="org-name-area">
          <!-- <div class="jurisdiction">Subject to Mumbai Jurisdiction</div> -->
          <div class="org-name"><span class="bold-b">B</span>EING <span class="bold-b">S</span>EVAK Charitable Trust</div>
          <div class="reg-line">Charity Commissioner (Reg.) No: E-31948, Certificate Under Section 80G of the Income Tax Act 1961</div>
          <div class="reg-line"> 80G Registration No: AACTB6422FF20214 &nbsp;CSR Registration No: CSR00015528</div>
          <div class="reg-line small">Registered Add: 401, 4th Floor, 'A' Wing, New Delite Apartment, Chandavarkar Lane, Borivali (West), Mumbai - 92.</div>
          <div class="reg-line small">Website: www.beingsevak.org &nbsp;Email: being.sevak@gmail.com &nbsp;Trust PAN CARD No: AACTB6422F</div>
          <div class="reg-line small">Helpline Number SEVAK: 8879-035-035 / 8879-034-034</div>
        </div>
      </div>

      <!-- Receipt Fields -->
      <table class="fields-table">
        <tr>
          <td class="label">Receipt No:</td>
          <td class="value underline" id="receipt-no-bot">79298</td>
          <td class="label text-right">Dated:</td>
          <td class="value underline" id="receipt-date-bot">1-Jun-26</td>
        </tr>
        <tr>
          <td class="label" colspan="1">RECEIVED with thanks from Ms./Mr./Miss.</td>
          <td class="value underline bold" colspan="3" id="donor-name-bot">Subramanyam Sridhar</td>
        </tr>
        <tr>
          <td class="label">Address:</td>
          <td class="value underline bold" colspan="3" id="address">NA</td>
        </tr>
        <tr>
          <td class="label">The Sum of Rupees:</td>
          <td class="value underline bold" colspan="3" id="amount-words-bot">One Thousand Five Hundred Rupees and No. Paise Only</td>
        </tr>
        <tr>
          <td class="label">Mode of Payment:</td>
          <td class="value underline bold" id="mode">Online</td>
          <td class="label">Payment ID No:</td>
          <td class="value underline bold" id="payment-id"> 615211600684</td>
        </tr>
        <tr>
          <td class="label">Bank Name:</td>
          <td class="value underline bold" id="bank">NA</td>
          <td colspan="2"></td>
        </tr>
        <tr>
          <td class="label">On Account Of:</td>
          <td class="value underline bold" colspan="3" id="account-of">Corpus</td>
        </tr>
      </table>

      <!-- Amount + PAN + Seal row -->
      <div class="amount-row">
        <div class="amount-box">
          <!-- <div class="amount-header">Amount (INR)</div> -->
          <div class="amount-value-row">
            <span class="amount-header"> Amount (INR)</span>
            <span class="rs">Rs.</span>
            <span class="amount-value" id="amount-fig-bot">1,500.00</span>
            <span class="pan-label">PAN NO:</span>
            <span class="pan-value" id="pan-no">NA</span>
          </div>
          <div class="realisation-note">Donation Payment is Subject to Realisation</div>
          <div class="email-row">Email ID: &nbsp;<span id="email">NA</span></div>
          <div class="jurisdiction">Subject to Mumbai Jurisdiction</div>
          <div class="system-note">****This is system generated auto receipt****</div>
        </div>
        <div class="seal-area">
          <!-- REPLACE: apni seal/stamp yahan daalein -->
          <img src="beingsevakstamp.png" alt="Seal" class="seal-img" onerror="this.style.display='none'" />
          <div class="auth-sign">Authorised Sign.<br/><strong>Being Sevak Charitable Trust</strong></div>
        </div>
      </div>

    </div>
  </div>

   <script src="script.js"></script> 
</body>
</html>
